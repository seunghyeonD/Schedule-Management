# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# Service role key (서버 전용, 관리 작업용 - 절대 클라이언트 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SECRET_OR_SERVICE_ROLE_KEY

# Kakao 주소검색 API
# https://developers.kakao.com/ → 애플리케이션 등록 → JavaScript 키
NEXT_PUBLIC_KAKAO_JS_KEY=YOUR_KAKAO_JS_KEY

# Kakao Local REST API 키 (서버 전용, 키워드 장소 검색용)
# https://developers.kakao.com/ → 앱 → 앱 키 → REST API 키
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY

# Google Sheets API (서비스 계정)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 동기화 대상 스프레드시트 ID
GOOGLE_SHEETS_SPREADSHEET_ID=YOUR_SPREADSHEET_ID

# 사이트 URL (OAuth 리다이렉트용)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
