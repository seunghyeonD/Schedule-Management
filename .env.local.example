# =====================================================================
# Supabase
# =====================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_PUBLISHABLE_OR_ANON_KEY

# =====================================================================
# Google OAuth (서버 — refresh token으로 access token 갱신)
# Google Cloud Console → API & Services → Credentials → OAuth 2.0 Client ID
# =====================================================================
GOOGLE_OAUTH_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-xxxxxxxx

# =====================================================================
# Google Picker (클라이언트 — 시트 선택 UI에서만 사용)
# https://developers.google.com/picker/docs
# =====================================================================
NEXT_PUBLIC_GOOGLE_PICKER_API_KEY=AIzaSyXXXXX
NEXT_PUBLIC_GOOGLE_PROJECT_NUMBER=000000000000

# =====================================================================
# Kakao Local REST API (서버 — 키워드 장소 검색)
# https://developers.kakao.com/ → 앱 → 앱 키 → REST API 키
# =====================================================================
KAKAO_REST_API_KEY=YOUR_KAKAO_REST_API_KEY

# =====================================================================
# 사이트 URL
#   - 로컬: http://localhost:3000
#   - 프로덕션: https://your-domain.vercel.app
# 카카오 KA 헤더의 origin, OAuth redirect 등에 사용
# =====================================================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
